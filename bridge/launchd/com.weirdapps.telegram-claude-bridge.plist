<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.weirdapps.telegram-claude-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/plessas/SourceCode/telegram-bot/bridge/launchd/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/plessas/SourceCode/telegram-bot</string>

