<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.weirdapps.telegram-claude-bridge</string>

    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/SourceCode/telegram-bot/bridge/launchd/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__HOME__/SourceCode/telegram-bot</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <!-- plan-004: KeepAlive=true (was {SuccessfulExit:false, Crashed:true}).
         The bridge handles SIGTERM gracefully and exits 0; under the old
         policy launchd treated that as "successful exit" and refused to
         restart, leaving the bridge silently down. ThrottleInterval=10
         (below) bounds restart loops. -->
    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/telegram-claude-bridge.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/telegram-claude-bridge.err.log</string>
</dict>
</plist>
