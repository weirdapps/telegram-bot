# Telegram User Client — configuration template
#
# Copy this file to `.env` in the project root and fill in real values.
# Every required variable below MUST be set. The application throws a
# ConfigError at startup on any missing value — there are NO fallbacks.

# MTProto application ID (positive integer). Obtain at https://my.telegram.org → "API development tools".
TELEGRAM_API_ID=123456

# MTProto application hash (32-char hex). Obtain on the same page as TELEGRAM_API_ID. Treat as a secret.
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Your own Telegram phone number in international format (with leading +).
TELEGRAM_PHONE_NUMBER=+306900000000

# Absolute filesystem path where the serialized GramJS StringSession is persisted after login.
# The file is equivalent to a password. Keep it on a path with mode 0600.
TELEGRAM_SESSION_PATH=/Users/me/.telegram/session.txt

# Absolute directory where incoming photo / voice / audio attachments are saved.
# Auto-created on startup if it does not exist.
TELEGRAM_DOWNLOAD_DIR=/Users/me/.telegram/downloads

# pino log level. One of: trace | debug | info | warn | error | silent
TELEGRAM_LOG_LEVEL=info

# OPTIONAL: 2FA password. The CLI does NOT read this value in v1 (it prompts
# interactively). Exposed here only for library consumers that bypass the CLI.
# TELEGRAM_2FA_PASSWORD=

# --- Bot API channel (optional) ---
# When set, the bridge ALSO listens for DMs to your bot. Get the token from
# BotFather (@BotFather on Telegram → /newbot or /token).
# TELEGRAM_BOT_TOKEN=123456789:AAH...
# Override the default voice download dir ($HOME/.telegram/bot-inbox)
# TELEGRAM_BRIDGE_BOT_TMPDIR=/tmp/bot-inbox

# --- Bot-only mode (optional) ---
# Set to "true" to disable the MTProto Saved Messages channel and run as
# bot-only (DMs to your bot are the sole input). Useful when you don't want
# the bridge logged into your personal Telegram account.
# TELEGRAM_BRIDGE_DISABLE_SAVED_MESSAGES=true
